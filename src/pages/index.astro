      </footer>
    </div>

    <script is:inline>
      (function () {
        const input = document.getElementById('input');
        const genBtn = document.getElementById('gen');
        const tryBtn = document.getElementById('try-example');
        const shareBtn = document.getElementById('share-url');
        const status = document.getElementById('status');
        const sizeEl = document.getElementById('size');
        const clientOut = document.getElementById('client-out');
        const typesOut = document.getElementById('types-out');
        const readmeOut = document.getElementById('readme-out');
        const toastHost = document.getElementById('toast-host');
        const MAX_BYTES = 50 * 1024;

        function b64encode(s) {
          return btoa(unescape(encodeURIComponent(s))).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
        }
        function b64decode(s) {
          s = s.replace(/-/g, '+').replace(/_/g, '/');
          while (s.length % 4) s += '=';
          try { return decodeURIComponent(escape(atob(s))); } catch (e) { return null; }
        }

        function renderSize() {
          const bytes = new TextEncoder().encode(input.value).length;
          sizeEl.textContent = bytes ? `${bytes.toLocaleString()} bytes` : '';
          sizeEl.classList.toggle('error', bytes > MAX_BYTES);
        }

        function setOutput(client, types, readme) {
          clientOut.textContent = client;
          typesOut.textContent = types;
          readmeOut.textContent = readme;
        }

        function showToast(message) {
          const div = document.createElement('div');
          div.className = 'toast';
          div.textContent = message;
          toastHost.appendChild(div);
          setTimeout(() => { div.classList.add('fade'); }, 4000);
          setTimeout(() => { try { div.remove(); } catch (_) {} }, 4600);
        }

        // Client-side secret scrub. Scans the input text and replaces secret-shaped
        // VALUES with <REDACTED> while preserving header NAMES so the LLM can
        // still detect auth pattern. Returns { scrubbed, count }.
        function scrubSecrets(text) {
          let count = 0;
          let out = text;

          // 1. Bearer tokens — three sub-patterns to cover HAR header objects + raw lines.
          //    1a. HAR header object with "name":"Authorization" + "value":"..."
          out = out.replace(/("name"\s*:\s*"authorization"\s*,\s*"value"\s*:\s*")[^"]+(")/gi, (_m, p1, p2) => {
            count += 1;
            return p1 + '<REDACTED>' + p2;
          });
          //    1b. "value":"Bearer ..." object (when name appears before)
          out = out.replace(/("value"\s*:\s*")Bearer\s+[^"]+(")/gi, (_m, p1, p2) => {
            count += 1;
            return p1 + 'Bearer <REDACTED>' + p2;
          });
          //    1c. raw HTTP line "Authorization: Bearer ..."
          out = out.replace(/(Authorization:\s*Bearer\s+)\S+/gi, (_m, p1) => {
            count += 1;
            return p1 + '<REDACTED>';
          });

          // 2. X-API-Key header value
          out = out.replace(/("name"\s*:\s*"x-api-key"\s*,\s*"value"\s*:\s*")[^"]+(")/gi, (_m, p1, p2) => {
            count += 1;
            return p1 + '<REDACTED>' + p2;
          });

          // 3. JWT-shaped values (3 base64url segments separated by dots)
          out = out.replace(/eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}/g, () => {
            count += 1;
            return '<REDACTED>';
          });

          // 4. AWS access key ids
          out = out.replace(/AKIA[0-9A-Z]{16}/g, () => {
            count += 1;
            return '<REDACTED>';
          });

          // 5. Stripe-style live/test keys inside a "value":"..." block
          out = out.replace(/("value"\s*:\s*")sk_(live|test)_[A-Za-z0-9]{16,}(")/gi, (_m, p1, _env, p3) => {
            count += 1;
            return p1 + '<REDACTED>' + p3;
          });

          return { scrubbed: out, count };
        }

        async function generate() {
          const harText = input.value.trim();
          if (!harText) {
            status.textContent = 'Paste a HAR first.';
            status.classList.add('error');
            return;
          }
          const bytes = new TextEncoder().encode(harText).length;
          if (bytes > MAX_BYTES) {
            status.textContent = `Input is ${bytes.toLocaleString()} bytes — max is ${MAX_BYTES.toLocaleString()}.`;
            status.classList.add('error');
            return;
          }

          // Client-side secret scrub BEFORE upload.
          const { scrubbed, count: redactedCount } = scrubSecrets(harText);
          let sendText = harText;
          if (redactedCount > 0) {
            sendText = scrubbed;
            // Reflect the scrubbed value back into the textarea so user sees exactly what was sent.
            input.value = scrubbed;
            renderSize();
            showToast(`🔒 Redacted ${redactedCount} secret-shaped value(s) before sending — see <REDACTED> markers in the input.`);
          }

          genBtn.disabled = true;
          status.classList.remove('error');
          status.classList.remove('notice');
          if (redactedCount > 0) {
            status.classList.add('redacted');
            status.textContent = `🔒 Redacted ${redactedCount} secret-shaped value(s) before sending. Generating…`;
          } else {
            status.classList.remove('redacted');
            status.textContent = 'Generating…';
          }
          const t0 = performance.now();
          try {
            const res = await fetch('/api/generate', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ har: sendText }),
            });
            const data = await res.json();
            if (!res.ok) {
              if (res.status === 429) {
                const m = (data && data.error || '').match(/~?(\d+)\s*m/);
                status.textContent = m
                  ? `You've hit 20 generations / hour. Try again in ~${m[1]}m.`
                  : "You've hit 20 generations / hour. Try again in a bit.";
              } else {
                status.textContent = (data && data.error) || ('HTTP ' + res.status);
              }
              status.classList.add('error');
              return;
            }
            setOutput(data.client || '', data.types || '', data.readme || '');
            const ms = Math.round(performance.now() - t0);
            status.classList.remove('redacted');
            if (data.truncated || (typeof data.notice === 'string' && data.notice.length > 0)) {
              status.classList.add('notice');
              const notice = data.notice || `⚠ Input was large; truncated to 50 endpoints.`;
              status.textContent = `Generated in ${ms} ms. ${notice}`;
            } else {
              status.textContent = `Generated in ${ms} ms.`;
            }
            try {
              location.hash = 'payload=' + b64encode(sendText);
            } catch (e) { /* ignore */ }
            track('generate_complete', { ms, bytes });
          } catch (e) {
            status.textContent = 'Network error: ' + e.message;
            status.classList.add('error');
          } finally {
            genBtn.disabled = false;
          }
        }

        function track(name, detail) {
          try { window.dispatchEvent(new CustomEvent(name, { detail })); } catch (_) {}
          try { window.dispatchEvent(new CustomEvent('har2sdk:' + name, { detail })); } catch (_) {}
          try { window.va && window.va('event', { name, data: detail }); } catch (_) {}
          try {
            if (window.goatcounter && typeof window.goatcounter.count === 'function') {
              window.goatcounter.count({ path: name, event: true, title: name });
            }
          } catch (_) {}
        }

        document.querySelectorAll('.copy-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const target = document.getElementById(btn.dataset.target);
            const text = target.textContent || '';
            if (!text || text.startsWith('// ') || text.startsWith('# ')) return;
            try {
              await navigator.clipboard.writeText(text);
              const orig = btn.textContent;
              btn.textContent = 'Copied';
              btn.classList.add('copied');
              setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1200);
            } catch (e) {
              btn.textContent = 'Copy failed';
            }
          });
        });

        input.addEventListener('input', renderSize);
        input.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
            e.preventDefault();
            generate();
          }
        });
        genBtn.addEventListener('click', generate);

        tryBtn.addEventListener('click', () => {
          input.value = input.placeholder;
          renderSize();
          generate();
        });

        shareBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(location.href);
            const orig = shareBtn.textContent;
            shareBtn.textContent = 'Link copied';
            shareBtn.classList.add('copied');
            setTimeout(() => { shareBtn.textContent = orig; shareBtn.classList.remove('copied'); }, 1400);
          } catch (e) {
            shareBtn.textContent = 'Copy failed';
          }
        });

        const waitlistForm = document.getElementById('waitlist-form');
        const waitlistEmail = document.getElementById('waitlist-email');
        const waitlistBtn = document.getElementById('waitlist-btn');
        const waitlistStatus = document.getElementById('waitlist-status');
        const waitlistContainer = document.getElementById('waitlist');
        const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        waitlistForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = (waitlistEmail.value || '').trim();
          if (!email || !EMAIL_RE.test(email)) {
            waitlistStatus.textContent = 'Please enter a valid email.';
            waitlistStatus.classList.add('error');
            return;
          }
          waitlistStatus.classList.remove('error');
          waitlistBtn.disabled = true;
          waitlistStatus.textContent = 'Sending…';
          try {
            const res = await fetch('/api/waitlist', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ email }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              if (res.status === 429) {
                waitlistStatus.textContent = "You've hit 5 signups / hour. Try again later.";
              } else {
                waitlistStatus.textContent = (data && data.error) || ('HTTP ' + res.status);
              }
              waitlistStatus.classList.add('error');
              waitlistBtn.disabled = false;
              return;
            }
            track('waitlist_signup', {});
            waitlistContainer.innerHTML = '<div class="done">Thanks — we’ll email you once when v1.1 ships.</div>';
          } catch (err) {
            waitlistStatus.textContent = 'Network error: ' + err.message;
            waitlistStatus.classList.add('error');
            waitlistBtn.disabled = false;
          }
        });

        // restore from URL fragment if present
        const hash = location.hash.replace(/^#/, '');
        const params = new URLSearchParams(hash);
        const payload = params.get('payload');
        if (payload) {
          const decoded = b64decode(payload);
          if (decoded) {
            input.value = decoded;
            renderSize();
            track('share_link_load', { bytes: new TextEncoder().encode(decoded).length });
            status.textContent = 'Loaded from URL. Press Generate to run.';
          }
        }
        renderSize();
      })();
    </script>
  </body>
</html>
