---
// har2sdk — paste HAR → typed TypeScript SDK
const sample = `{
  "log": {
    "version": "1.2",
    "creator": {"name": "Chrome", "version": "120"},
    "entries": [
      {
        "request": {
          "method": "GET",
          "url": "https://api.example.com/v1/users/42",
          "headers": [{"name": "Authorization", "value": "Bearer eyJhbGciOi..."}],
          "queryString": []
        },
        "response": {
          "status": 200,
          "content": {"mimeType": "application/json", "text": "{\\"id\\":42,\\"name\\":\\"Ada\\",\\"email\\":\\"ada@example.com\\"}"}
        }
      },
      {
        "request": {
          "method": "POST",
          "url": "https://api.example.com/v1/messages",
          "headers": [{"name": "Authorization", "value": "Bearer eyJhbGciOi..."}, {"name": "content-type", "value": "application/json"}],
          "postData": {"mimeType": "application/json", "text": "{\\"to\\":42,\\"text\\":\\"hi\\"}"}
        },
        "response": {
          "status": 201,
          "content": {"mimeType": "application/json", "text": "{\\"id\\":\\"msg_1\\",\\"sent\\":true}"}
        }
      }
    ]
  }
}`;
