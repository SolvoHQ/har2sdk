  <body>
    <div class="wrap">
      <header>
        <h1>har<span class="y">2sdk</span></h1>
        <div class="tag">
          <a href="https://github.com/SolvoHQ/har2sdk" target="_blank" rel="noopener">github</a>
          · <a href="https://jsontosdk.vercel.app/" target="_blank" rel="noopener">jsontosdk</a>
          · <a href="https://dotenv2types.vercel.app/" target="_blank" rel="noopener">dotenv2types</a>
        </div>
      </header>
      <p class="pitch">
        Paste a HAR (Chrome/Firefox network export) → typed TypeScript SDK with LLM-named methods,
        resource grouping, and auth detection. No signup.
        <span class="kbd">⌘</span>+<span class="kbd">Enter</span> to generate.
      </p>

      <div id="toast-host"></div>

      <div class="row input-row">
        <div class="panel">
